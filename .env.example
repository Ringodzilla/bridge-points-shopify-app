SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_customers,read_orders,read_store_credit_accounts,read_store_credit_account_transactions,write_store_credit_account_transactions
SHOPIFY_APP_URL=https://your-production-app-domain.example.com
SHOP_CUSTOM_DOMAIN=
SHOPIFY_BILLING_TEST_MODE=true
ORDER_PAID_RETRY_JOB_SECRET=
SHOPIFY_BILLING_TEST_INCLUDED_ORDERS_OVERRIDE=
SHOPIFY_BILLING_TEST_INCLUDED_ORDERS_OVERRIDE_FREE=
SHOPIFY_BILLING_TEST_INCLUDED_ORDERS_OVERRIDE_ADVANCED=
SHOPIFY_BILLING_TEST_INCLUDED_ORDERS_OVERRIDE_PREMIUM=

# Production values before App Store submission:
# SHOPIFY_APP_URL=https://bridgepoint-shopify-app.fly.dev
# SHOPIFY_BILLING_TEST_MODE=false
#
# Local development uses the default Prisma SQLite schema.
DATABASE_URL=file:./prisma/dev.sqlite

# Production on Fly.io should use Supabase Postgres with prisma-postgres/schema.prisma.
# For v1 stability, set both DATABASE_URL and DIRECT_URL to the same Supabase direct connection.
# A pooled DATABASE_URL can be revisited after the Supabase pooler username/host is verified.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

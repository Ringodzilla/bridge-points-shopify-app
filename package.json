{
  "name": "bridge-points",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "build:prod": "npm run prisma:prod:generate && npm run build",
    "dev": "npm run dev:bridge",
    "dev:bridge": "npm run shopify -- app dev --config bridgepoint",
    "config:link": "npm run shopify -- app config link --config bridgepoint",
    "generate": "npm run shopify -- app generate",
    "deploy": "npm run shopify -- app deploy --config bridgepoint",
    "config:use": "npm run shopify -- app config use bridgepoint",
    "env": "npm run shopify -- app env show --config bridgepoint",
    "preview:info": "node scripts/dev-preview-info.mjs",
    "preview:open": "node scripts/dev-preview-info.mjs --open",
    "release:precheck": "node scripts/release-precheck.mjs",
    "release:validate-config": "npm run shopify -- app config validate --config bridgepoint --json",
    "review:precommit": "node scripts/precommit-review.mjs",
    "ci:local": "npm run release:validate-config && npm run release:precheck && npm test",
    "prepush:ci": "node scripts/prepush-ci.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "setup:local": "prisma generate && node scripts/setup-local-db.mjs",
    "setup:prod": "npm run prisma:prod:generate && npm run prisma:prod:migrate",
    "prisma:prod:generate": "prisma generate --schema prisma-postgres/schema.prisma",
    "prisma:prod:migrate": "prisma migrate deploy --schema prisma-postgres/schema.prisma",
    "lint": "eslint --ignore-path .eslintignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "npx @shopify/cli@latest",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "test": "npm run verify"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.17.0",
    "@react-router/fs-routes": "^7.17.0",
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "isbot": "^5.1.31",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.17.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^2.0.0",
    "@shopify/polaris-types": "1.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "workspaces": {
    "packages": [
      "extensions/*"
    ]
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  }
}
